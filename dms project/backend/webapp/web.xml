:root {
    --bg-color: #05050A;
    --panel-bg: rgba(20, 20, 30, 0.6);
    --panel-border: rgba(255, 255, 255, 0.08);
    --text-main: #FFFFFF;
    --text-muted: #8B949E;
    --accent: #00F0FF;
    --accent-glow: rgba(0, 240, 255, 0.4);
    --accent-secondary: #FF2A6D;
    --font-sans: 'Inter', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background-color: var(--bg-color);
    color: var(--text-main);
    font-family: var(--font-sans);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
}

/* Dynamic Background grid and glow */
.background-animation {
    position: fixed;
    top: 0; left: 0; width: 100vw; height: 100vh;
    background: 
        radial-gradient(circle at 15% 50%, rgba(0, 240, 255, 0.05), transparent 25%),
        radial-gradient(circle at 85% 30%, rgba(255, 42, 109, 0.05), transparent 25%);
    z-index: -1;
    pointer-events: none;
}

.container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
}

/* Header */
.header {
    margin-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
}

.logo {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 0.5rem;
}

.orb {
    width: 24px;
    height: 24px;
    background: var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 20px var(--accent-glow), 0 0 40px var(--accent-glow);
    animation: pulse 2s infinite ease-in-out alternate;
}

@keyframes pulse {
    0% { transform: scale(0.9); box-shadow: 0 0 10px var(--accent-glow); }
    100% { transform: scale(1.1); box-shadow: 0 0 30px var(--accent-glow); }
}

h1 {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -1px;
}

h1 span {
    color: var(--accent);
}

.subtitle {
    color: var(--text-muted);
    font-size: 1.1rem;
    font-family: var(--font-mono);
}

/* Dashboard Layout */
.dashboard {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 2rem;
}

/* Glassmorphism Panels */
.glass {
    background: var(--panel-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--panel-border);
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    transition: transform 0.3s ease, border-color 0.3s ease;
}

.glass:hover {
    border-color: rgba(0, 240, 255, 0.2);
}

h2 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--accent);
}

/* Controls Panel */
.controls-panel {
    display: flex;
    flex-direction: column;
    gap: 2rem;
}

.control-group label {
    display: block;
    margin-bottom: 0.8rem;
    font-weight: 600;
    font-size: 0.95rem;
}

.control-group label span {
    color: var(--accent);
    font-family: var(--font-mono);
}

input[type=range] {
    -webkit-appearance: none;
    width: 100%;
    background: transparent;
    margin-bottom: 0.5rem;
}

input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    height: 18px;
    width: 18px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    margin-top: -6px;
    box-shadow: 0 0 10px var(--accent-glow);
    transition: transform 0.1s;
}

input[type=range]::-webkit-slider-thumb:hover {
    transform: scale(1.2);
}

input[type=range]::-webkit-slider-runnable-track {
    width: 100%;
    height: 6px;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    border: 1px solid rgba(255, 255, 255, 0.05);
}

.description {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.4;
}

/* Metrics */
.metrics {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: auto;
}

.metric-card {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 1.5rem;
    border-radius: 12px;
}

.metric-card h3 {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
}

.metric-card .value {
    font-family: var(--font-mono);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--accent-secondary);
    text-shadow: 0 0 15px rgba(255, 42, 109, 0.3);
}

/* Visualizations */
.viz-panel {
    display: flex;
    flex-direction: column;
    gap: 2rem;
}

.viz-container {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
}

.chart-wrapper {
    flex-grow: 1;
    position: relative;
    min-height: 300px;
    width: 100%;
}

.bottom-viz {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    height: 350px;
}

.small-viz {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
}

.small-viz h2 {
    align-self: flex-start;
    width: 100%;
}

canvas#phaseCanvas {
    background: radial-gradient(circle at center, rgba(0, 240, 255, 0.05) 0%, transparent 70%);
    border-radius: 50%;
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.5) inset;
}

.hint {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 1rem;
    text-align: center;
}

.info-panel {
    align-items: flex-start;
    justify-content: flex-start;
}

.info-panel p {
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
    line-height: 1.5;
}

.info-panel strong {
    color: #fff;
    display: block;
    margin-bottom: 0.3rem;
    font-family: var(--font-mono);
}

.footnote {
    font-size: 0.8rem !important;
    color: var(--text-muted);
    font-style: italic;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 1rem;
    margin-top: auto;
}

/* Responsive */
@media (max-width: 1024px) {
    .dashboard {
        grid-template-columns: 1fr;
    }
    .bottom-viz {
        grid-template-columns: 1fr;
        height: auto;
    }
}
